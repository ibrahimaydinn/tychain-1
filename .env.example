# ─── Tychain — environment template ───────────────────────────────────────────
# Copy to `.env` for local development. NEVER commit a populated .env.
# In production these are set as Hugging Face Space "Variables and secrets".

# === Turso (libSQL) ==========================================================
# Get the URL from: turso db show <database> --url
# Get the token  from: turso db tokens create <database>
TURSO_DATABASE_URL=libsql://<your-database>.turso.io
TURSO_AUTH_TOKEN=<paste-jwt-here>

# Optional: enable embedded-replica mode (local read replica synced from remote).
# Leave unset for plain remote-only mode.
# TURSO_SYNC_URL=libsql://<your-database>.turso.io

# Optional: override local SQLite path (used only when TURSO_DATABASE_URL is unset
# OR TURSO_SYNC_URL is set).
# TYCHAIN_DB_PATH=/data/tychain.db

# === Flask ===================================================================
# 64-hex-char random string. Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<paste-random-hex-here>

# Public URL of the deployed app (used in alert email links)
APP_URL=https://huggingface.co/spaces/<user>/<space>

# === Email (SMTP) ============================================================
# Leaving SMTP_HOST unset puts email_helper in mock-log mode (safe for dev).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=<your-smtp-user>
SMTP_PASS=<app-password-not-account-password>
MAIL_FROM=alerts@yourdomain.tld
MAIL_NAME=Tychain Alerts
SMTP_TIMEOUT=20
